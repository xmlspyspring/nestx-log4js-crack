{
  "name": "nestx-log4js-crack",
  "version": "1.5.3",
  "private": true,
  "scripts": {
    "bootstrap": "lerna bootstrap",
    "format": "prettier --write \"packages/*/src/**/*.ts\"",
    "lint": "eslint \"packages/*/src/**/*.ts\" --fix",
    "test": "jest",
    "test:cov": "jest --coverage",
    "build": "lerna run build",
    "release": "semantic-release"
  },
  "dependencies": {
    "@nestjs/common": "^8.4.7 || ^9.0.0 || ^10.0.0 || ^11.0.0",
    "@nestjs/core": "^9.0.5 || ^10.0.0 || ^11.0.0",
    "@nestjs/platform-express": "^8.4.7 || ^9.0.0 || ^10.0.0 || ^11.0.0",
    "reflect-metadata": "0.2.2",
    "rimraf": "5.0.10",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^9.4.2 || ^10.0.0 || ^11.0.0",
    "@nestjs/schematics": "^9.0.4 || ^10.0.0 || ^11.0.0",
    "@nestjs/testing": "^8.4.7 || ^9.0.0 || ^10.0.0 || ^11.0.0",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/exec": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "@types/express": "5.0.6",
    "@types/jest": "29.5.14",
    "@types/node": "22.19.12",
    "@types/supertest": "7.2.0",
    "@typescript-eslint/eslint-plugin": "5.62.0",
    "@typescript-eslint/parser": "5.62.0",
    "eslint": "8.57.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.5",
    "jest": "29.7.0",
    "lerna": "6.6.2",
    "prettier": "3.8.1",
    "semantic-release": "19.0.5",
    "sinon": "21.0.1",
    "supertest": "7.2.2",
    "ts-jest": "29.2.5",
    "ts-loader": "9.5.4",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3"
  },
  "release": {
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/github",
      "@semantic-release/npm",
      "@semantic-release/changelog",
      [
        "@semantic-release/exec",
        {
          "prepareCmd": "lerna exec --concurrency 1 -- npm version ${nextRelease.version} && lerna version ${nextRelease.version} --no-git-tag-version --no-push --amend --yes",
          "publishCmd": "lerna exec --concurrency 1 -- npm publish --access public --registry=https://registry.npmjs.org"
        }
      ],
      [
        "@semantic-release/git",
        {
          "assets": [
            "CHANGELOG.md",
            "lerna.json",
            "package.json",
            "packages/*/package.json"
          ],
          "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
        }
      ]
    ]
  }
}
